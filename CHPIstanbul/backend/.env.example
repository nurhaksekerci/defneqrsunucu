DEBUG=True
SECRET_KEY=dev-CHANGE-ME-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Admin / formlar için HTTPS kökleri (boşsa ve DEBUG=False ise CORS listesi kullanılır)
# CSRF_TRUSTED_ORIGINS=https://app.example.com,https://api.example.com

# TLS sonlandırma reverse proxy arkasında (nginx, load balancer)
# USE_TLS_BEHIND_PROXY=True

# DEBUG=False + tarayıcıdan http:// ile API (127.0.0.1:8000 vb.): açık bırakırsanız tüm istekler
# HTTPS'e yönlendirilir; CORS preflight (OPTIONS) yönlendirilemez → giriş/API çağrıları kırılır.
# Yerel veya Docker'da düz HTTP kullanıyorsanız:
# SECURE_SSL_REDIRECT=False
# SECURE_HSTS_SECONDS=0

# Gerçek üretimde HTTPS (veya proxy arkasında USE_TLS_BEHIND_PROXY) ile bu değerleri açın.
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000

# İsteğe bağlı: çok büyük rapor yüklemeleri (bayt; varsayılan 32MB)
# DATA_UPLOAD_MAX_MEMORY_SIZE=33554432
# FILE_UPLOAD_MAX_MEMORY_SIZE=33554432

# Log seviyesi: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO
# DJANGO_LOG_LEVEL=INFO

# DRF hız limitleri (örnek)
# DRF_THROTTLE_ANON=120/hour
# DRF_THROTTLE_USER=600/hour
# DRF_THROTTLE_TOKEN_OBTAIN=15/minute
# DRF_THROTTLE_TOKEN_REFRESH=60/minute

# PostgreSQL — üretimde DEBUG=False iken zorunlu
# DATABASE_ENGINE=django.db.backends.postgresql
# DATABASE_NAME=chpistanbul
# DATABASE_USER=postgres
# DATABASE_PASSWORD=secret
# DATABASE_HOST=localhost
# DATABASE_PORT=5432

# Yerel MEDIA_ROOT dosyalarını Django üzerinden sun (DEBUG=False; yalnızca güvendiğiniz ortamda)
# SERVE_MEDIA=True

# S3 uyumlu nesne depolama (rapor görselleri; boşsa yerel MEDIA_ROOT)
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=eu-central-1
# AWS_ACCESS_KEY_ID=   # IAM veya ortam rolleri (ör. ECS) ile de verilebilir
# AWS_SECRET_ACCESS_KEY=
# MinIO vb. için:
# AWS_S3_ENDPOINT_URL=http://minio:9000
# AWS_S3_CUSTOM_DOMAIN=
