# Kopyalayıp .env oluşturun:
#   PowerShell: Copy-Item .env.example .env
# Sonra POSTGRES_PASSWORD ve DJANGO_SECRET_KEY değerlerini doldurun.
#
# Yerel geliştirme — PostgreSQL. Docker Compose kullanıyorsanız çoğu değişken
# kök dizindeki docker-compose.yml + kök .env üzerinden gelir; bu şablon `runserver` içindir.

DJANGO_SECRET_KEY=dev-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=defneqr_chp
POSTGRES_USER=defneqr
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Production (DEBUG=false): virgülle ayrı
# CORS_ALLOWED_ORIGINS=https://chp.defneqr.com
# CSRF_TRUSTED_ORIGINS=https://api-chp.defneqr.com
