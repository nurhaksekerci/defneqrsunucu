# Kopyalayıp .env oluşturun:  cp .env.example .env
#
# —— Yerel (runserver): POSTGRES_HOST=localhost
# —— Sunucu Docker: POSTGRES_HOST=postgres  (compose içindeki servis adı)
#
# Zorunlu: DJANGO_SECRET_KEY (üretimde uzun rastgele değer; openssl rand -hex 32)

DJANGO_SECRET_KEY=dev-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=defneqr_chp
POSTGRES_USER=defneqr
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Production (DEBUG=false): tam köken (şema + host + port), virgülle ayrı.
# Tarayıcıdaki web uygulaması (ör. frontend-chp) farklı kökende ise mutlaka ekleyin;
# aksi halde login vb. istekler CORS ile bloklanır.
CORS_ALLOWED_ORIGINS=https://chp.defneqr.com,http://localhost:3010
CSRF_TRUSTED_ORIGINS=https://api-chp.defneqr.com
