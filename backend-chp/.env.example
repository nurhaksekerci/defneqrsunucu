# Yerel geliştirme — PostgreSQL (Docker postgres servisi ile uyumlu)
# docker-compose içinde POSTGRES_* olarak geçirilir; bu dosya sadece referans.

DJANGO_SECRET_KEY=dev-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=defneqr_chp
POSTGRES_USER=defneqr
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Production (DEBUG=false): virgülle ayrı
# CORS_ALLOWED_ORIGINS=https://chp.defneqr.com
# CSRF_TRUSTED_ORIGINS=https://api-chp.defneqr.com
