// Prisma Schema - DefneRandevu Appointment Service (db-randevu)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Randevu Durumları
enum AppointmentStatus {
  PENDING      // Bekliyor
  CONFIRMED    // Onaylandı
  COMPLETED    // Tamamlandı
  CANCELLED    // İptal edildi
  NO_SHOW      // Gelmedi
  POSTPONED    // Ertelendi
}

// Gelir/Gider türü
enum FinanceEntryType {
  INCOME   // Gelir
  EXPENSE  // Gider
}

// İşletme (DefneRandevu - kuaför, berber, klinik vb.)
model AppointmentBusiness {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  description   String?
  address       String?
  phone         String?
  logo          String?

  ownerId       String   // No User FK - references users in backend-common

  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  staff         AppointmentStaff[]
  services      AppointmentService[]
  customers     AppointmentCustomer[]
  appointments  Appointment[]
  workingHours  AppointmentWorkingHours[]
  smsLogs       AppointmentSmsLog[]
  financeEntries FinanceEntry[]
  receivables   Receivable[]
  customerPackages CustomerPackage[]
  products      AppointmentProduct[]

  @@index([ownerId])
  @@index([slug])
  @@index([isDeleted])
  @@map("appointment_businesses")
}

// Personel
model AppointmentStaff {
  id            String   @id @default(uuid())
  businessId    String
  business      AppointmentBusiness @relation(fields: [businessId], references: [id], onDelete: Cascade)

  fullName      String
  phone         String?
  specialty     String?
  color         String?  // Takvim rengi (#hex)
  notes         String?  @db.Text
  isActive      Boolean  @default(true)

  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  staffServices AppointmentStaffService[]
  workingHours  AppointmentWorkingHours[]
  appointments  Appointment[]

  @@index([businessId])
  @@index([isDeleted])
  @@map("appointment_staff")
}

// Hizmet
model AppointmentService {
  id            String   @id @default(uuid())
  businessId    String
  business      AppointmentBusiness @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name          String
  duration      Int      // Dakika
  price         Decimal  @db.Decimal(10, 2)
  description   String?  @db.Text

  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  staffServices AppointmentStaffService[]
  appointments  Appointment[]
  customerPackages CustomerPackage[]

  @@index([businessId])
  @@index([isDeleted])
  @@map("appointment_services")
}

// Personel-Hizmet ilişkisi (personel bazlı süre/fiyat override)
model AppointmentStaffService {
  id            String   @id @default(uuid())
  staffId       String
  staff         AppointmentStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)
  serviceId     String
  service       AppointmentService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  duration      Int?     // null = service.duration kullan
  price         Decimal? @db.Decimal(10, 2)  // null = service.price kullan

  @@unique([staffId, serviceId])
  @@index([staffId])
  @@index([serviceId])
  @@map("appointment_staff_services")
}

// Çalışma saatleri (personel veya işletme bazlı)
model AppointmentWorkingHours {
  id            String   @id @default(uuid())
  businessId    String
  business      AppointmentBusiness @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staffId       String?
  staff         AppointmentStaff? @relation(fields: [staffId], references: [id], onDelete: Cascade)

  dayOfWeek     Int      // 0=Pazar, 1=Pazartesi, ..., 6=Cumartesi
  startTime     String   // "09:00"
  endTime       String   // "18:00"
  isClosed      Boolean  @default(false)

  @@index([businessId])
  @@index([staffId])
  @@index([businessId, staffId, dayOfWeek])
  @@map("appointment_working_hours")
}

// Müşteri
model AppointmentCustomer {
  id            String   @id @default(uuid())
  businessId    String
  business      AppointmentBusiness @relation(fields: [businessId], references: [id], onDelete: Cascade)

  fullName      String
  phone         String
  email         String?

  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  appointments  Appointment[]
  receivables   Receivable[]
  customerPackages CustomerPackage[]

  @@index([businessId])
  @@index([phone])
  @@index([isDeleted])
  @@map("appointment_customers")
}

// Randevu
model Appointment {
  id            String           @id @default(uuid())
  businessId    String
  business      AppointmentBusiness @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staffId       String
  staff         AppointmentStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)
  serviceId     String
  service       AppointmentService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  customerId    String
  customer      AppointmentCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  startAt       DateTime
  endAt         DateTime
  status        AppointmentStatus @default(PENDING)
  notes         String?          @db.Text

  // Tekrar eden randevu
  seriesId      String?          // Aynı serideki randevuları gruplar
  recurrenceType String?         // WEEKLY | BIWEEKLY | MONTHLY
  recurrenceEndDate DateTime?    // Tekrarın biteceği tarih

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reminders     AppointmentReminder[]
  packageUsages PackageUsage[]
  financeEntries FinanceEntry[]

  @@index([businessId])
  @@index([staffId])
  @@index([customerId])
  @@index([startAt])
  @@index([status])
  @@index([businessId, startAt])
  @@index([seriesId])
  @@map("appointments")
}

// SMS Log
model AppointmentSmsLog {
  id            String   @id @default(uuid())
  businessId    String
  business      AppointmentBusiness @relation(fields: [businessId], references: [id], onDelete: Cascade)

  phone         String
  message       String   @db.Text
  smsHeader     String?
  sentAt        DateTime @default(now())
  status        String?  // success, failed
  providerResponse String? @db.Text

  @@index([businessId])
  @@index([sentAt])
  @@map("appointment_sms_logs")
}

// Randevu hatırlatması gönderim kaydı (tekrar gönderimi önlemek için)
model AppointmentReminder {
  id            String   @id @default(uuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  channel       String   // SMS | EMAIL
  reminderType  String   // 24H | 3H | 1H
  sentAt        DateTime @default(now())

  @@unique([appointmentId, channel, reminderType])
  @@index([appointmentId])
  @@map("appointment_reminders")
}

// Gelir ve Gider kayıtları
model FinanceEntry {
  id            String          @id @default(uuid())
  businessId    String
  business      AppointmentBusiness @relation(fields: [businessId], references: [id], onDelete: Cascade)

  type          FinanceEntryType
  amount        Decimal         @db.Decimal(10, 2)
  date          DateTime
  category      String          // Randevu, Ürün, Kira, Maaş, Malzeme, Diğer vb.
  description   String?         @db.Text

  appointmentId String?
  appointment   Appointment?    @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  isDeleted     Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  @@index([businessId])
  @@index([type])
  @@index([date])
  @@index([businessId, type, date])
  @@index([isDeleted])
  @@map("finance_entries")
}

// Alacak (müşteri borcu)
model Receivable {
  id            String   @id @default(uuid())
  businessId    String
  business      AppointmentBusiness @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId    String
  customer      AppointmentCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  totalAmount   Decimal  @db.Decimal(10, 2)
  dueDate       DateTime?
  description   String?  @db.Text

  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  payments      ReceivablePayment[]

  @@index([businessId])
  @@index([customerId])
  @@index([isDeleted])
  @@map("receivables")
}

// Alacak tahsilatı
model ReceivablePayment {
  id            String     @id @default(uuid())
  receivableId  String
  receivable    Receivable @relation(fields: [receivableId], references: [id], onDelete: Cascade)

  amount        Decimal    @db.Decimal(10, 2)
  paidAt        DateTime   @default(now())
  notes         String?    @db.Text

  createdAt     DateTime   @default(now())

  @@index([receivableId])
  @@map("receivable_payments")
}

// Müşteri paketi (örn: 10 seans)
model CustomerPackage {
  id               String   @id @default(uuid())
  businessId       String
  business         AppointmentBusiness @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId       String
  customer         AppointmentCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  serviceId        String
  service          AppointmentService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  totalSessions    Int      // Toplam seans (örn: 10)
  remainingSessions Int     // Kalan seans
  purchasedAt      DateTime @default(now())
  expiresAt        DateTime? // Opsiyonel bitiş tarihi
  expiryWarningSentAt DateTime? // Bitiş uyarısı gönderildi mi
  notes            String?  @db.Text

  isDeleted        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  usages           PackageUsage[]

  @@index([businessId])
  @@index([customerId])
  @@index([serviceId])
  @@index([expiresAt])
  @@index([isDeleted])
  @@map("customer_packages")
}

// Paket kullanımı (randevu tamamlandığında 1 seans düşülür)
model PackageUsage {
  id            String   @id @default(uuid())
  packageId     String
  package       CustomerPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  usedAt        DateTime @default(now())

  @@unique([appointmentId])
  @@index([packageId])
  @@index([appointmentId])
  @@map("package_usages")
}

// Satışa sunulan ürünler (kuaförde şampuan, krem vb.)
model AppointmentProduct {
  id            String   @id @default(uuid())
  businessId    String
  business      AppointmentBusiness @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name          String
  sku           String?  // Stok kodu
  price         Decimal  @db.Decimal(10, 2)
  stockQuantity Int?

  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  sales         ProductSale[]

  @@index([businessId])
  @@index([isDeleted])
  @@map("appointment_products")
}

// Ürün satış kaydı
model ProductSale {
  id            String   @id @default(uuid())
  productId     String
  product       AppointmentProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  quantity      Int
  unitPrice     Decimal  @db.Decimal(10, 2)
  totalAmount   Decimal  @db.Decimal(10, 2)
  customerId    String?
  soldAt        DateTime @default(now())
  notes         String?  @db.Text

  @@index([productId])
  @@index([soldAt])
  @@map("product_sales")
}
